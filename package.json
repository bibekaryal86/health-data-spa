    "prettier:write": "prettier --write \"**/*.+(js|jsx|ts|tsx)\"",
    "lint": "eslint src/**",
    "lint:fix": "npm run lint -- --fix",
    "test": "jest --config ./jest.config.js --passWithNoTests",
    "test:u": "npm run test -- -u"
